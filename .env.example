# Application Environment Variables

# Node Environment
NODE_ENV=development

# ==========================================
# Sentry Configuration
# ==========================================
# Get your DSN from https://sentry.io or use self-hosted Sentry
SENTRY_DSN=
VITE_SENTRY_DSN=

# SENTRY_SECRET_KEY is managed by the LAOS stack.
# You do not need it in this app repo.

# ==========================================
# PostHog Configuration
# ==========================================
# For self-hosted PostHog (LAOS)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=http://localhost:8001

# For PostHog Cloud (uncomment if using cloud)
# VITE_POSTHOG_KEY=your-project-api-key
# VITE_POSTHOG_HOST=https://app.posthog.com

# Server-side PostHog (same as client for self-hosted)
POSTHOG_API_KEY=
POSTHOG_HOST=http://localhost:8001

# POSTHOG_SECRET_KEY is managed by the LAOS stack.
# You do not need it in this app repo.

# ==========================================
# Grafana Stack Configuration
# ==========================================
# Loki endpoint for logs
LOKI_ENDPOINT=http://localhost:3100/loki/api/v1/push

# OpenTelemetry endpoint for traces (Tempo, base URL, no path suffix)
OTLP_ENDPOINT=http://localhost:4318

# Loki OTLP endpoint for structured logs (base URL, no path suffix)
LOKI_OTLP_ENDPOINT=http://localhost:3100/otlp

# ==========================================
# Pyroscope (Continuous Profiling)
# ==========================================
PYROSCOPE_SERVER_ADDRESS=http://localhost:4040
SERVICE_NAME=effect-tanstack-start

# ==========================================
# Database (if needed for your app)
# ==========================================
DATABASE_URL=postgresql://user:password@localhost:5432/mydb
